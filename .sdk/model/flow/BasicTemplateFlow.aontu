# BasicTemplateFlow

main: kit: flow: BasicTemplateFlow:
{
  entity: "template",
  kind: "basic",
  name: "BasicTemplateFlow",
  step: [
    {
      input: {
        ref: "template_ref01"
      }

      op: "create"
    }

    {
      op: "list",
      valid: [
        {
          apply: "ItemExists",
          def: {
            ref: "template_ref01"
          }
        }
      ]
    }

    {
      input: {
        ref: "template_ref01",
        srcdatavar: "template_ref01_data",
        suffix: "_dt0"
      }

      match: {
        id: "template01"
      }

      op: "load",
      valid: [
        {
          apply: "TextFieldMark",
          def: {
            mark: "Mark01-template_ref01"
          }
        }
      ]
    }

    {
      input: {
        ref: "template_ref01",
        suffix: "_rm0"
      }

      match: {
        id: "template01"
      }

      op: "remove"
    }

    {
      input: {
        suffix: "_rt0"
      }

      op: "list",
      valid: [
        {
          apply: "ItemNotExists",
          def: {
            ref: "template_ref01"
          }
        }
      ]
    }
  ],
  "key$": "BasicTemplateFlow"
}